# Required: Admin password (min 12 chars)
ADMIN_KEY=your_secret_password_here

# ── Storage Backend (choose one) ──

# Option A: Neon Postgres (recommended — Vercel native, set via Vercel Dashboard)
# DATABASE_URL=postgres://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Option B: Upstash Redis (create at https://console.upstash.com)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx

# Option C: Memory (for demo/development)
# DEMO_MODE=true
# MEMORY_STORAGE=true

# CORS
# CORS_ORIGIN=https://yourdomain.com

# Optional
# RSW_BITS=2048
# WIDGET_VERSION=latest
# WASM_VERSION=latest
# IPINFO_TOKEN=
